<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.scnu.hospitalmanagementinformationsystem.mapper.DepartmentMapper">
    <resultMap id="DepartmentResultMap" type="cn.edu.scnu.hospitalmanagementinformationsystem.entity.Department">
        <constructor>
            <idArg column="id" javaType="java.lang.Long" />
            <arg column="name" javaType="java.lang.String" />
            <arg column="location" javaType="java.lang.String" />
        </constructor>
    </resultMap>

    <select id="findAll" resultMap="DepartmentResultMap">
        SELECT id, name, location
        FROM departments
        <where>
            <if test="keyword != null and keyword != ''">
                name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id
    </select>

    <select id="findById" resultMap="DepartmentResultMap">
        SELECT id, name, location
        FROM departments
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO departments (name, location)
        VALUES (#{name}, #{location})
    </insert>

    <update id="update">
        UPDATE departments
        SET name = #{name},
            location = #{location}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM departments WHERE id = #{id}
    </delete>
</mapper>
