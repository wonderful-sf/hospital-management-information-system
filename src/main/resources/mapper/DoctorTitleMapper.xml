<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.scnu.hospitalmanagementinformationsystem.mapper.DoctorTitleMapper">
    <resultMap id="DoctorTitleResultMap" type="cn.edu.scnu.hospitalmanagementinformationsystem.entity.DoctorTitle">
        <constructor>
            <idArg column="id" javaType="java.lang.Long" />
            <arg column="name" javaType="java.lang.String" />
            <arg column="consultation_fee" javaType="java.math.BigDecimal" />
        </constructor>
    </resultMap>

    <select id="findAll" resultMap="DoctorTitleResultMap">
        SELECT id, name, consultation_fee
        FROM doctor_titles
        <where>
            <if test="keyword != null and keyword != ''">
                name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id
    </select>

    <select id="findById" resultMap="DoctorTitleResultMap">
        SELECT id, name, consultation_fee
        FROM doctor_titles
        WHERE id = #{id}
    </select>

    <insert id="insert">
        INSERT INTO doctor_titles (name, consultation_fee)
        VALUES (#{name}, #{consultationFee})
    </insert>

    <update id="update">
        UPDATE doctor_titles
        SET name = #{name},
            consultation_fee = #{consultationFee}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM doctor_titles WHERE id = #{id}
    </delete>

    <select id="lastInsertId" resultType="java.lang.Long">
        SELECT LAST_INSERT_ID()
    </select>
</mapper>
