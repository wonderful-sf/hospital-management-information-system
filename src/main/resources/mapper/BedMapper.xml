<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.scnu.hospitalmanagementinformationsystem.mapper.BedMapper">
    <resultMap id="BedResultMap" type="cn.edu.scnu.hospitalmanagementinformationsystem.entity.Bed">
        <constructor>
            <idArg column="id" javaType="java.lang.Long" />
            <arg column="ward_id" javaType="java.lang.Long" />
            <arg column="bed_no" javaType="java.lang.String" />
            <arg column="status" javaType="cn.edu.scnu.hospitalmanagementinformationsystem.entity.BedStatus" />
        </constructor>
    </resultMap>

    <select id="findAll" resultMap="BedResultMap">
        SELECT id, ward_id, bed_no, status
        FROM beds
        <where>
            <if test="keyword != null and keyword != ''">
                bed_no LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id
    </select>

    <select id="findById" resultMap="BedResultMap">
        SELECT id, ward_id, bed_no, status
        FROM beds
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO beds (ward_id, bed_no, status)
        VALUES (#{wardId}, #{bedNo}, #{status})
    </insert>

    <update id="update">
        UPDATE beds
        SET ward_id = #{wardId},
            bed_no = #{bedNo},
            status = #{status}
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE beds SET status = #{status} WHERE id = #{id}
    </update>
</mapper>
